# Database (AWS Lightsail / RDS)
RDS_ENDPOINT=your-db-endpoint.region.rds.amazonaws.com
RDS_USER=postgres
RDS_PASSWORD=your-password
RDS_DATABASE=dauchy
RDS_PORT=5432

# Session
SESSION_SECRET=your-long-random-secret

# App domain (used for building public URLs of uploaded images)
APP_DOMAIN=your-domain.com

# OpenAI
OPENAI_API_KEY=sk-...

# Google Cloud Storage (for image uploads)
# Option A: inline JSON key
GCS_KEY_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}

# Option B: path to key file (set in container via volume mount or secrets)
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcs-key.json

# GCS bucket paths
PRIVATE_OBJECT_DIR=/your-bucket-name/private
PUBLIC_OBJECT_SEARCH_PATHS=/your-bucket-name/public
